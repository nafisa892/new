{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A service offered by Nafisa Asoti",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "price", "description"]
    },
    "Message": {
      "title": "Message",
      "description": "Contact form submission from a client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "requirement": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] }
      },
      "required": ["name", "email", "requirement", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "link": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "image"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global editable site settings",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "aboutText": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" }
      },
      "required": ["heroTitle"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Simple site tracking",
      "type": "object",
      "properties": {
        "views": { "type": "number" },
        "serviceClicks": { "type": "object" }
      }
    }
  },
  "firestore": {
    "services": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "messages": {
      "schema": "Message",
      "description": "Client messages"
    },
    "projects": {
      "schema": "Project",
      "description": "Portfolio projects"
    },
    "settings": {
      "schema": "SiteSettings",
      "description": "Site-wide configuration"
    },
    "analytics": {
      "schema": "Analytics",
      "description": "User analytics"
    }
  }
}
